-- RESET DE DATOS DE PRUEBA
-- 3 usuarios: admin, lector, bibliotecario
-- Passwords sin hash (para pre-alpha con hasheo desactivado)
-- Cuando actives SHA-256 reemplaza los valores de password
-- con el hash correspondiente
-- ============================================================

-- Limpiar tablas en orden para respetar FK
DELETE FROM multa;
DELETE FROM prestamo;
DELETE FROM libro_autor;
DELETE FROM libro;
DELETE FROM usuario;
DELETE FROM editorial;
DELETE FROM categoria;
DELETE FROM autor;

-- Reiniciar contadores autoincrement en SQLite
DELETE FROM sqlite_sequence WHERE name IN (
    'multa','prestamo','libro_autor','libro',
    'usuario','editorial','categoria','autor'
);

-- ============================================================
-- USUARIOS
-- ============================================================
INSERT INTO usuario (documento, nombres, apellidos, email, telefono, password, tipo_usuario, estado) VALUES
    ('1000001', 'Admin',        'Sistema',    'admin@admin.com',  '3000000001', 'admin',  'admin',        'activo'),
    ('1000002', 'Lector',       'Prueba',     'lector@lector.com','3000000002', 'lector', 'lector',       'activo'),
    ('1000003', 'Bibliotecario','Prueba',     'bibli@bibli.com',  '3000000003', 'bibli',  'bibliotecario','activo');

-- ============================================================
-- DATOS MÍNIMOS PARA PODER PROBAR LIBROS Y PRÉSTAMOS
-- ============================================================
INSERT INTO editorial (nombre, pais, sitio_web) VALUES
    ('Editorial Prueba', 'Colombia', 'https://prueba.com');

INSERT INTO categoria (nombre, descripcion) VALUES
    ('Tecnología', 'Libros de tecnología y software');

INSERT INTO autor (nombres, apellidos, nacionalidad) VALUES
    ('Autor', 'Prueba', 'Colombiano');

INSERT INTO libro (titulo, isbn, anio_publicacion, num_paginas, id_editorial, id_categoria, estado) VALUES
    ('Libro Disponible 1', '111-1', 2024, 100, 1, 1, 'disponible'),
    ('Libro Disponible 2', '111-2', 2024, 200, 1, 1, 'disponible'),
    ('Libro Prestado',     '111-3', 2024, 300, 1, 1, 'prestado');

INSERT INTO libro_autor (id_libro, id_autor) VALUES (1,1),(2,1),(3,1);

-- Préstamo activo para el lector
INSERT INTO prestamo (id_libro, id_usuario, fecha_prestamo, fecha_devolucion_esperada, estado) VALUES
    (3, 2, DATE('now'), DATE('now', '+15 days'), 'activo');</sql><current_tab id="0"/></tab_sql></sqlb_project>
