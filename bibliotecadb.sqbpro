-- ============================================================
-- VISTAS útiles para consultas frecuentes
-- ============================================================

-- Vista: libros con editorial y categoría
CREATE VIEW IF NOT EXISTS v_libros_detalle AS
SELECT
    l.id_libro,
    l.titulo,
    l.isbn,
    l.anio_publicacion,
    l.num_paginas,
    l.estado,
    e.nombre  AS editorial,
    c.nombre  AS categoria
FROM libro l
LEFT JOIN editorial e ON l.id_editorial = e.id_editorial
LEFT JOIN categoria c ON l.id_categoria = c.id_categoria;

-- Vista: préstamos activos con datos del libro y usuario
CREATE VIEW IF NOT EXISTS v_prestamos_activos AS
SELECT
    p.id_prestamo,
    l.titulo                      AS libro,
    u.nombres || ' ' || u.apellidos AS usuario,
    u.email,
    p.fecha_prestamo,
    p.fecha_devolucion_esperada,
    p.estado
FROM prestamo p
JOIN libro   l ON p.id_libro   = l.id_libro
JOIN usuario u ON p.id_usuario = u.id_usuario
WHERE p.estado = 'activo';

-- Vista: multas pendientes con datos del usuario
CREATE VIEW IF NOT EXISTS v_multas_pendientes AS
SELECT
    m.id_multa,
    u.nombres || ' ' || u.apellidos AS usuario,
    u.email,
    l.titulo                        AS libro,
    m.monto,
    m.fecha_generacion,
    m.estado                        AS estado_multa
FROM multa m
JOIN prestamo p ON m.id_prestamo = p.id_prestamo
JOIN usuario  u ON p.id_usuario  = u.id_usuario
JOIN libro    l ON p.id_libro    = l.id_libro
WHERE m.estado = 'pendiente';

