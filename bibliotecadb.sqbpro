olumn_widths><column index="1" value="72"/><column index="2" value="210"/><column index="3" value="117"/><column index="4" value="280"/><column index="5" value="156"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="libro" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="51"/><column index="2" value="265"/><column index="3" value="117"/><column index="4" value="102"/><column index="5" value="83"/><column index="6" value="74"/><column index="7" value="79"/><column index="8" value="65"/><column index="9" value="156"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="libro_autor" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="53"/><column index="2" value="57"/><column index="3" value="156"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="multa" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="58"/><column index="2" value="80"/><column index="3" value="62"/><column index="4" value="156"/><column index="5" value="85"/><column index="6" value="78"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="sqlite_sequence" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="78"/><column index="2" value="29"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="usuario" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="67"/><column index="2" value="140"/><column index="3" value="109"/><column index="4" value="124"/><column index="5" value="210"/><column index="6" value="85"/><column index="7" value="117"/><column index="8" value="70"/><column index="9" value="156"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">
-- NOTA DE PORTABILIDAD:
--   SQLite  → Este archivo funciona tal cual.
--   MySQL   → Cambiar TEXT por VARCHAR(n), INTEGER PRIMARY KEY
--             AUTOINCREMENT por INT AUTO_INCREMENT PRIMARY KEY,
--             añadir ENGINE=InnoDB DEFAULT CHARSET=utf8mb4,
--             y activar CHECK con MySQL 8.0+.
--   PostgreSQL → Cambiar INTEGER PRIMARY KEY AUTOINCREMENT por
--             SERIAL PRIMARY KEY, BOOLEAN soportado nativamente,
--             TEXT y VARCHAR funcionan igual.
-- ============================================================

PRAGMA foreign_keys = ON;   -- Habilitar integridad referencial en SQLite

-- ============================================================
-- 1. EDITORIAL
-- ============================================================
CREATE TABLE IF NOT EXISTS editorial (
    id_editorial  INTEGER PRIMARY KEY AUTOINCREMENT,
    nombre        TEXT    NOT NULL,
    pais          TEXT,
    sitio_web     TEXT
);

-- ============================================================
-- 2. CATEGORIA
-- ============================================================
CREATE TABLE IF NOT EXISTS categoria (
    id_categoria  INTEGER PRIMARY KEY AUTOINCREMENT,
    nombre        TEXT    NOT NULL,
    descripcion   TEXT
);

-- ============================================================
-- 3. AUTOR
-- ============================================================
CREATE TABLE IF NOT EXISTS autor (
    id_autor          INTEGER PRIMARY KEY AUTOINCREMENT,
    nombres           TEXT    NOT NULL,
    apellidos         TEXT    NOT NULL,
    nacionalidad      TEXT,
    fecha_nacimiento  TEXT    -- formato ISO: YYYY-MM-DD
);

-- ============================================================
-- 4. USUARIO
-- ============================================================
CREATE TABLE IF NOT EXISTS usuario (
    id_usuario    INTEGER PRIMARY KEY AUTOINCREMENT,
    documento     TEXT    NOT NULL UNIQUE,
    nombres       TEXT    NOT NULL,
    apellidos     TEXT    NOT NULL,
    email         TEXT    NOT NULL UNIQUE,
    telefono      TEXT,
    -- tipo_usuario: 'admin' | 'lector'
    tipo_usuario  TEXT    NOT NULL DEFAULT 'lector'
                          CHECK (tipo_usuario IN ('admin', 'lector')),
    -- estado: 'activo' | 'inactivo' | 'suspendido'
    estado        TEXT    NOT NULL DEFAULT 'activo'
                          CHECK (estado IN ('activo', 'inactivo', 'suspendido'))
);

-- ============================================================
-- 5. LIBRO
--    disponible se maneja como VARCHAR para enum en el código:
--    'disponible' | 'prestado' | 'mantenimiento' | 'dado_de_baja'
-- ============================================================
CREATE TABLE IF NOT EXISTS libro (
    id_libro          INTEGER PRIMARY KEY AUTOINCREMENT,
    titulo            TEXT    NOT NULL,
    isbn              TEXT    UNIQUE,
    anio_publicacion  INTEGER,
    num_paginas       INTEGER CHECK (num_paginas &gt; 0),
    id_editorial      INTEGER,
    id_categoria      INTEGER,
    -- Estado del libro manejado como enum en el código
    estado            TEXT    NOT NULL DEFAULT 'disponible'
                              CHECK (estado IN ('disponible', 'prestado',
                                                'mantenimiento', 'dado_de_baja')),
    FOREIGN KEY (id_editorial) REFERENCES editorial(id_editorial)
        ON UPDATE CASCADE ON DELETE SET NULL,
    FOREIGN KEY (id_categoria) REFERENCES categoria(id_categoria)
        ON UPDATE CASCADE ON DELETE SET NULL
);

-- ============================================================
-- 6. LIBRO_AUTOR  (tabla intermedia N:M)
-- ============================================================
CREATE TABLE IF NOT EXISTS libro_autor (
    id_libro   INTEGER NOT NULL,
    id_autor   INTEGER NOT NULL,
    PRIMARY KEY (id_libro, id_autor),
    FOREIGN KEY (id_libro) REFERENCES libro(id_libro)
        ON UPDATE CASCADE ON DELETE CASCADE,
    FOREIGN KEY (id_autor) REFERENCES autor(id_autor)
        ON UPDATE CASCADE ON DELETE CASCADE
);

-- ============================================================
-- 7. PRESTAMO
-- ============================================================
CREATE TABLE IF NOT EXISTS prestamo (
    id_prestamo               INTEGER PRIMARY KEY AUTOINCREMENT,
    id_libro                  INTEGER NOT NULL,
    id_usuario                INTEGER NOT NULL,
    fecha_prestamo            TEXT    NOT NULL DEFAULT (DATE('now')), -- YYYY-MM-DD
    fecha_devolucion_esperada TEXT    NOT NULL,
    fecha_devolucion_real     TEXT,   -- NULL mientras no se devuelva
    -- estado: 'activo' | 'devuelto' | 'vencido'
    estado                    TEXT    NOT NULL DEFAULT 'activo'
                                      CHECK (estado IN ('activo', 'devuelto', 'vencido')),
    FOREIGN KEY (id_libro)   REFERENCES libro(id_libro)
        ON UPDATE CASCADE ON DELETE RESTRICT,
    FOREIGN KEY (id_usuario) REFERENCES usuario(id_usuario)
        ON UPDATE CASCADE ON DELETE RESTRICT
);

-- ============================================================
-- 8. MULTA
-- ============================================================
CREATE TABLE IF NOT EXISTS multa (
    id_multa          INTEGER PRIMARY KEY AUTOINCREMENT,
    id_prestamo       INTEGER NOT NULL UNIQUE,  -- 1 multa por préstamo
    monto             REAL    NOT NULL CHECK (monto &gt;= 0),
    fecha_generacion  TEXT    NOT NULL DEFAULT (DATE('now')),
    fecha_pago        TEXT,   -- NULL mientras no se pague
    -- estado: 'pendiente' | 'pagada' | 'exonerada'
    estado            TEXT    NOT NULL DEFAULT 'pendiente'
                              CHECK (estado IN ('pendiente', 'pagada', 'exonerada')),
    FOREIGN KEY (id_prestamo) REFERENCES prestamo(id_prestamo)
        ON UPDATE CASCADE ON DELETE RESTRICT
);

-- ============================================================
-- ÍNDICES  (mejoran rendimiento en consultas frecuentes)
-- ============================================================
CREATE INDEX IF NOT EXISTS idx_libro_titulo       ON libro(titulo);
CREATE INDEX IF NOT EXISTS idx_libro_isbn         ON libro(isbn);
CREATE INDEX IF NOT EXISTS idx_libro_estado       ON libro(estado);
CREATE INDEX IF NOT EXISTS idx_usuario_documento  ON usuario(documento);
CREATE INDEX IF NOT EXISTS idx_usuario_email      ON usuario(email);
CREATE INDEX IF NOT EXISTS idx_prestamo_estado    ON prestamo(estado);
CREATE INDEX IF NOT EXISTS idx_prestamo_usuario   ON prestamo(id_usuario);
CREATE INDEX IF NOT EXISTS idx_prestamo_libro     ON prestamo(id_libro);
CREATE INDEX IF NOT EXISTS idx_multa_estado       ON multa(estado);

